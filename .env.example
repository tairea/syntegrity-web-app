# Copy to .env and fill in. .env is gitignored.
# NOTE: VITE_-prefixed vars are bundled into client-side code and are therefore
# PUBLIC. The OpenRouter key below is fine for local prototyping, but before any
# real deployment route LLM calls through a Supabase edge function so the key
# never reaches the browser.

VITE_OPENROUTER_API_KEY=sk-or-...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_pub_...
