# Copy to .env and fill in. .env is gitignored.
# NOTE: VITE_-prefixed vars are bundled into client-side code and are therefore
# PUBLIC. The two below are public by design (the Supabase publishable/anon key is
# gated by row-level security).
#
# The OpenRouter API key is NOT here: LLM calls go through the Supabase Edge
# Function `openrouter` (supabase/functions/openrouter/index.ts), which holds the
# key server-side so it never reaches the browser. Set it as a Supabase secret:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-... --project-ref <ref>

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
